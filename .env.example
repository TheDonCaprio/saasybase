# SaaSyBase environment template
# Copy to .env.local for development. Do not commit real secrets.

# ============================================================================
# Core app / runtime
# ============================================================================
# [server][required] Database connection. SQLite is fine for local dev.
DATABASE_URL="file:./dev.db"
# [client][required] Public base URL used by redirects, emails, and embeds.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# [client][required] Public app domain used in links and email copy.
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
# [server][optional] Explicit server-side auth/app URL override for NextAuth.
NEXTAUTH_URL="http://localhost:3000"
# [client][required] Site brand name.
NEXT_PUBLIC_SITE_NAME="SaaSyBase"
# [client][optional] Branded logo asset URLs for header/theme rendering.
NEXT_PUBLIC_SITE_LOGO=""
NEXT_PUBLIC_SITE_LOGO_LIGHT=""
NEXT_PUBLIC_SITE_LOGO_DARK=""
NEXT_PUBLIC_SITE_LOGO_HEIGHT="48"

# ============================================================================
# Auth provider selection
# ============================================================================
# [server+client][required] Options: "clerk", "nextauth"
AUTH_PROVIDER="nextauth"

# Clerk
# [client][required when AUTH_PROVIDER=clerk]
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# [server][required when AUTH_PROVIDER=clerk]
CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# NextAuth
# [server][required when AUTH_PROVIDER=nextauth] Generate with: npx auth secret
AUTH_SECRET=""
# [server][optional] Keep in sync with AUTH_SECRET for compatibility with NextAuth/Auth.js tooling.
NEXTAUTH_SECRET=""
# [server][optional] OAuth providers for NextAuth.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# [server][optional] Non-interactive seed overrides for the initial admin user.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# ============================================================================
# Payment provider selection / shared payment config
# ============================================================================
# [server+client][required] Options: "stripe", "paystack", "paddle", "razorpay"
PAYMENT_PROVIDER="stripe"
# [server][optional] Environment fallback currency for payment flows/catalog sync.
# Admin DEFAULT_CURRENCY takes precedence when set.
PAYMENTS_CURRENCY="USD"
# [server][optional] Generic catalog sync enable flag for all configured providers.
PAYMENT_AUTO_CREATE="true"

# ============================================================================
# Stripe
# ============================================================================
# [client][required when Stripe checkout is used]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# [server][required when Stripe is configured]
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================================================
# Paystack
# ============================================================================
# [server][required when Paystack is configured]
PAYSTACK_SECRET_KEY=""
# [client][required when Paystack checkout is used]
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# [server][optional] Advanced Paystack-specific currency override.
PAYSTACK_CURRENCY="NGN"

# ============================================================================
# Paddle
# ============================================================================
# [server][required when Paddle is configured]
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
# [client][required when Paddle checkout is used]
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
# [server][recommended when Paddle is configured] Enables provider-side catalog creation from seeded plans.
PADDLE_AUTO_CREATE="false"
# [server][required for provider-side catalog creation]
PADDLE_DEFAULT_TAX_CATEGORY="standard"
# [server][optional] Tax category used by some Paddle sync paths.
PADDLE_TAX_CATEGORY="standard"
# [server][optional] Advanced Paddle-specific currency override.
PADDLE_CURRENCY="USD"
# [server+client][required when using Paddle sandbox]
PADDLE_ENV="sandbox"
NEXT_PUBLIC_PADDLE_ENV="sandbox"
# [server+client][optional] Alternative sandbox toggles.
PADDLE_SANDBOX="1"
NEXT_PUBLIC_PADDLE_SANDBOX="1"
# [server][optional] API base URL override.
PADDLE_API_BASE_URL="https://sandbox-api.paddle.com"
# [server][optional] Webhook signature tolerance in seconds.
PADDLE_WEBHOOK_TOLERANCE_SECONDS="300"
# [server][optional] Extra debug logging for subscription update flows.
PADDLE_DEBUG_SUBSCRIPTION_UPDATES="0"

# ============================================================================
# Razorpay
# ============================================================================
# [client][required when Razorpay checkout is used]
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
# [server][required when Razorpay is configured]
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# [server][optional] Attach offer_id to one-time payment links.
RAZORPAY_ENABLE_OFFERS="true"
# [server][optional] Advanced Razorpay-specific currency override.
RAZORPAY_CURRENCY="USD"

# ============================================================================
# Seeded plan/provider price ids
# ============================================================================
# [server][optional] One-time plan ids from provider dashboards or catalog sync.
PAYMENT_PRICE_24H="price_24H"
PAYMENT_PRICE_7D="price_7D"
PAYMENT_PRICE_1M_OT="price_1M_OT"
# [server][optional] Recurring plan ids from provider dashboards or catalog sync.
SUBSCRIPTION_PRICE_1M="price_1M_SUB"
SUBSCRIPTION_PRICE_3M="price_3M_SUB"
SUBSCRIPTION_PRICE_1Y="price_1Y_SUB"

# ============================================================================
# Email / support
# ============================================================================
# [server][optional] Email transport backend. Options: "nodemailer", "resend"
EMAIL_PROVIDER="nodemailer"
# [server][required when EMAIL_PROVIDER=nodemailer for real delivery; dev can use MailHog]
SMTP_HOST="::1"
SMTP_PORT="1025"
SMTP_USER="admin@saasybase.com"
SMTP_PASS="password"
# [server][required when EMAIL_PROVIDER=resend]
RESEND_API_KEY=""
# SMTP settings are ignored when EMAIL_PROVIDER="resend".
# [server][required] Default sender/support identities.
EMAIL_FROM="support@saasybase.com"
SUPPORT_EMAIL="support@saasybase.com"
# [server][optional] Admin billing notification toggle.
SEND_ADMIN_BILLING_EMAILS="true"
# [server][optional] Additional outbound email target used by some workflows.
PARTNERS_EMAIL="partners@saasybase.com"
# [server][optional] IPinfo Lite token for commercial-safe country-level session geolocation.
IPINFO_LITE_TOKEN=""

# ============================================================================
# Storage / branding assets
# ============================================================================
# [server][optional] Logo/file storage backend configuration.
LOGO_STORAGE=""
LOGO_S3_BUCKET=""
LOGO_S3_ENDPOINT=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
LOGO_CDN_DOMAIN=""

# ============================================================================
# Analytics
# ============================================================================
# [client][optional] GA4 browser tracking.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# [server][optional] GA Data API / reporting.
GA_PROPERTY_ID=""
GA_SERVICE_ACCOUNT_CREDENTIALS_B64=""
GA_DATA_API_CACHE_SECONDS="300"
GA_LIFETIME_START_DATE=""

# ============================================================================
# Security / internal ops
# ============================================================================
# [server][required in production] Used to encrypt sensitive data at rest, including reusable payment authorizations.
ENCRYPTION_SECRET=""
# [server][optional in dev, should be false in prod unless intentionally enabled]
ALLOW_ADMIN_SCRIPT="false"
# [server][optional] Enable read-only product demo mode (blocks mutating /api requests except auth/webhooks)
DEMO_READ_ONLY_MODE="false"
# [server][required in production for detailed health diagnostics]
HEALTHCHECK_TOKEN="$"
# [server][recommended in production] Used by internal/server-to-server endpoints.
INTERNAL_API_TOKEN=""
# [server][required in production] Used by /api/cron/process-expiry.
CRON_PROCESS_EXPIRY_TOKEN=""

# ============================================================================
# Local development / testing helpers
# ============================================================================
# [server][optional] Local dev admin bootstrap.
DEV_ADMIN_ID=""
DEV_ADMIN_EMAIL=""
# [server][optional] Playwright smoke/e2e credentials.
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
PLAYWRIGHT_E2E_EMAIL=""
PLAYWRIGHT_E2E_PASSWORD=""
PLAYWRIGHT_E2E_ADMIN_EMAIL=""
PLAYWRIGHT_E2E_ADMIN_PASSWORD=""
PLAYWRIGHT_ORG_FROM=""
PLAYWRIGHT_ORG_TO=""
PLAYWRIGHT_ORG_DELETE=""
# [server][optional] Run e2e assertions that expect read-only demo behavior
PLAYWRIGHT_DEMO_READ_ONLY="false"
# [server][optional] Misc local test helper.
TEST_EMAIL=""
