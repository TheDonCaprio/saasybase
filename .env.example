# Local env for development - do not commit
# Use SQLite dev DB created by Prisma migration
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
NEXT_PUBLIC_SITE_NAME="SaaSyBase"

#Paymnt Provider selection
PAYMENT_PROVIDER="stripe" # Options: "stripe", "paystack", "paddle", "lemonsqueezy" "razorpay"

# Auth Provider selection
AUTH_PROVIDER="clerk" # Options: "clerk", "nextauth"

# Clerk (required when AUTH_PROVIDER=clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# NextAuth (required when AUTH_PROVIDER=nextauth)
AUTH_SECRET=""  # Generate with: npx auth secret
# Optional OAuth providers for NextAuth:
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_AUTO_CREATE="1"

# Paystack (uncomment to enable)
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

# Lemon Squeezy (No longer supported)
# LEMONSQUEEZY_API_KEY="
# Numeric store ID. eg 12345
# LEMONSQUEEZY_STORE_ID=""
# Comma-separated allowed (e.g. for secret rotation): "whsec_old,whsec_new"
#LEMONSQUEEZY_WEBHOOK_SECRET=""
# Optional: include Lemon Squeezy in admin catalog sync
#LEMONSQUEEZY_ENABLE_CATALOG_SYNC="0"

# Razorpay (uncomment to enable)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
RAZORPAY_ENABLE_OFFERS="true"  # Optional: attach offer_id to one-time Payment Links (see README)
# Optional (recommended if your merchant is not INR-only): currency to use for Razorpay.
# This affects catalog sync (plan creation) and redirect checkouts.
RAZORPAY_CURRENCY="USD"



# Paddle (commented; enable by setting PAYMENT_PROVIDER="paddle")
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
PADDLE_DEFAULT_TAX_CATEGORY="standard" # required for admin auto-create of products/prices
PADDLE_ENV="sandbox" # or "production" (omit for production)
NEXT_PUBLIC_PADDLE_ENV="sandbox" # or "production" (omit for production)
PADDLE_SANDBOX="1" # optional alternative to PADDLE_ENV
NEXT_PUBLIC_PADDLE_SANDBOX="1" # optional alternative to PADDLE_ENV
PADDLE_API_BASE_URL="https://sandbox-api.paddle.com" # optional override

# SMTP / support defaults
SMTP_HOST="::1"
SMTP_PORT="1025"
SMTP_USER="admin@saasybase.com"
SMTP_PASS="password"
EMAIL_FROM="support@saasybase.com"
SUPPORT_EMAIL="support@saasybase.com"
SEND_ADMIN_BILLING_EMAILS="true"

# Used to encrypt sensitive data before storing in the DB (e.g. card last4)
ENCRYPTION_SECRET=""

# Local dev user (Clerk user ID)
DEV_ADMIN_ID=""
DEV_ADMIN_EMAIL=""

# Placeholder Stripe price IDs (replace with real price IDs for checkout tests)
# These represent one-time purchase prices and must map to Stripe Prices with type=one_time
PAYMENT_PRICE_1H="price_1H"
PAYMENT_PRICE_24H="price_24H"
PAYMENT_PRICE_7D="price_7D"
PAYMENT_PRICE_1M="price_1M"
PAYMENT_PRICE_3M="price_3M"
PAYMENT_PRICE_1Y="price_1Y"

# Optional: Uncomment if you enable autoRenew on any plan and point these to Stripe Prices with type=recurring
SUBSCRIPTION_PRICE_1M="price_monthly_subscription"
SUBSCRIPTION_PRICE_3M="price_quarterly_subscription"
SUBSCRIPTION_PRICE_1Y="price_yearly_subscription"

# Stripe webhook (test): run `stripe listen --forward-to localhost:3000/api/stripe/webhook` and copy secret into STRIPE_WEBHOOK_SECRET

# Amazon S3 (optional, for production)
LOGO_STORAGE=""
LOGO_S3_BUCKET=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
LOGO_CDN_DOMAIN="" # Optional CDN domain for uploaded logos

# Google Analytics 4 (optional)
# Tracking runs in every environment once these are set. Use a dev property if you want to keep production data tidy.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
GA_PROPERTY_ID=""

# Encode your service account JSON with `base64 -i key.json` before pasting below.
GA_SERVICE_ACCOUNT_CREDENTIALS_B64=""
GA_DATA_API_CACHE_SECONDS=""

# Allow make-admin script to create an admin user if none exist (true by default for dev; should be false in production with a strong INTERNAL_API_TOKEN set)
ALLOW_ADMIN_SCRIPT="false"

# Health check token (required in production to access detailed /api/health diagnostics)
HEALTHCHECK_TOKEN="$"

# Internal / server-to-server endpoints (recommended in production)
# Used by /api/internal/* and some admin/debug tooling.
INTERNAL_API_TOKEN=""

# Cron endpoints (required in production)
# Used by /api/cron/process-expiry.
CRON_PROCESS_EXPIRY_TOKEN=""
