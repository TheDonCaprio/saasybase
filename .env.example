# SaaSyBase environment template
# Copy to .env.local for development. Do not commit real secrets.

# ============================================================================
# Core app / runtime
# ============================================================================
# [server][required] Database connection. SQLite is fine for local dev.
DATABASE_URL="file:./dev.db"
# [client][required] Public base URL used by redirects, emails, and embeds.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# [server][optional] Explicit server-side auth/app URL override for NextAuth / Better Auth compatibility.
NEXTAUTH_URL="http://localhost:3000"
# [server][optional] Explicit Better Auth base URL used for callbacks and trusted origin resolution.
BETTER_AUTH_URL="http://localhost:3000"
# [client][optional] Public Better Auth base URL override for client auth helpers.
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
# [client][required] Public app domain used in links and email copy.
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
# [client][required] Site brand name.
NEXT_PUBLIC_SITE_NAME="SaaSyBase"
# [server][optional] Content Security Policy is disabled by default in the
# boilerplate. Set to "true" only if you want to maintain a strict allowlist.
ENABLE_CSP="false"
# [client][optional] Branded logo asset URLs for header/theme rendering.
NEXT_PUBLIC_SITE_LOGO=""
NEXT_PUBLIC_SITE_LOGO_LIGHT=""
NEXT_PUBLIC_SITE_LOGO_DARK=""
NEXT_PUBLIC_SITE_LOGO_HEIGHT="48"


# ============================================================================
# Auth provider selection
# ============================================================================
# [server+client][required] Options: "clerk", "nextauth", "betterauth"
AUTH_PROVIDER="betterauth"

# Clerk
# [client][required when AUTH_PROVIDER=clerk]
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# [server][required when AUTH_PROVIDER=clerk] Secret key for Clerk server SDK access.
CLERK_SECRET_KEY=""
# [server][required when AUTH_PROVIDER=clerk] Webhook signing secret for Clerk events.
CLERK_WEBHOOK_SECRET=""

# Better Auth / NextAuth compatibility
# [server][required when AUTH_PROVIDER=betterauth or AUTH_PROVIDER=nextauth] Generate with: npx auth secret
BETTER_AUTH_SECRET=""
# [server][required when AUTH_PROVIDER=betterauth or AUTH_PROVIDER=nextauth] Shared fallback secret.
AUTH_SECRET=""
# [server][optional] Keep in sync with BETTER_AUTH_SECRET / AUTH_SECRET for compatibility with NextAuth/Auth.js tooling.
NEXTAUTH_SECRET=""
# [server][optional] Shared OAuth provider credentials for Better Auth / NextAuth.
# Both Better Auth and NextAuth use these GitHub/Google credentials when
# AUTH_PROVIDER points at their lane. Leave them blank to disable those buttons.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# [server][optional] Non-interactive seed overrides for the initial admin user.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""


# ============================================================================
# Payment provider selection / shared payment config
# ============================================================================
# [server+client][required] Options: "stripe", "paystack", "paddle", "razorpay"
PAYMENT_PROVIDER="stripe"
# [server][optional] Environment fallback currency for payment flows/catalog sync.
# Admin DEFAULT_CURRENCY takes precedence when set.
PAYMENTS_CURRENCY="USD"
# [server][optional] Generic catalog sync enable flag for all configured providers.
PAYMENT_AUTO_CREATE="true"


# ============================================================================
# Stripe
# ============================================================================
# [client][required when Stripe checkout is used]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# [server][required when Stripe is configured] Secret API key for server-side billing calls.
STRIPE_SECRET_KEY=""
# [server][required when Stripe webhooks are configured] Endpoint signing secret.
STRIPE_WEBHOOK_SECRET=""


# ============================================================================
# Paystack
# ============================================================================
# [server][required when Paystack is configured]
PAYSTACK_SECRET_KEY=""
# [client][required when Paystack checkout is used]
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# [server][optional] Advanced Paystack-specific currency override.
PAYSTACK_CURRENCY="NGN"


# ============================================================================
# Paddle
# ============================================================================
# [server][required when Paddle is configured]
PADDLE_API_KEY=""
# [server][required when Paddle webhooks are configured] Supports comma-separated
# rotation when replacing webhook signing secrets.
PADDLE_WEBHOOK_SECRET=""
# [client][required when Paddle checkout is used]
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
# [server][required] Paddle environment selector. Use "sandbox" for test mode and "production" for live mode.
PADDLE_ENV="sandbox"
# [client][required] Client-side Paddle environment selector for sandbox/live script loading.
NEXT_PUBLIC_PADDLE_ENV="sandbox"
# [server][required when PAYMENT_AUTO_CREATE=true for Paddle catalog sync]
# Use a Paddle-supported tax category such as "standard".
PADDLE_DEFAULT_TAX_CATEGORY="standard"
# [server][optional] Advanced Paddle-specific currency override.
PADDLE_CURRENCY="USD"
# [server][optional] Webhook signature tolerance in seconds.
PADDLE_WEBHOOK_TOLERANCE_SECONDS="300"
# [server][optional] Extra debug logging for subscription update flows.
PADDLE_DEBUG_SUBSCRIPTION_UPDATES="0"


# ============================================================================
# Razorpay
# ============================================================================
# [client][required when Razorpay checkout is used]
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
# [server][required when Razorpay is configured]
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# [server][optional] Attach offer_id to one-time payment links.
RAZORPAY_ENABLE_OFFERS="true"
# [server][optional] Advanced Razorpay-specific currency override.
RAZORPAY_CURRENCY="USD"


# ============================================================================
# Optional secrets-provider bootstrap
# ============================================================================
# [server][optional] Leave these blank for platform-native envs, .env.local,
# or any deployment target that injects secrets directly. Set SECRETS_PROVIDER
# when you want SaaSyBase to pre-load missing server secrets from Infisical or
# Doppler before build/start/Prisma commands.
SECRETS_PROVIDER="" # infisical or doppler
# [server][optional] Infisical defaults to: infisical export --format json
INFISICAL_PROJECT_ID=""
INFISICAL_ENVIRONMENT=""
# [server][optional] Doppler defaults to: doppler secrets download --no-file --format json
DOPPLER_PROJECT=""
DOPPLER_CONFIG=""

# [server][optional] Override the provider command entirely.
SECRETS_PROVIDER_COMMAND=""
# [server][optional] Comma-separated allowlist of env vars to load. Leave blank to allow any missing provider keys.
SECRETS_PROVIDER_SECRETS=""

# ============================================================================
# Optional Sentry error reporting
# ============================================================================
# [server][optional] Leave blank unless you want external error monitoring in
# addition to the built-in SystemLog admin view. When enabled, production WARN
# and ERROR logger events still persist locally and also forward to Sentry.
# Recommended values for SENTRY_ENABLED: "true" to enable, or leave blank /
# set "false" to disable. The runtime also accepts "1", "yes", and "on" as
# truthy values, but "true" is the clearest documented choice.
SENTRY_ENABLED=""
# [server][optional] Set to "true" only when you want logger WARN/ERROR fan-out
# to Sentry during local development. Production ignores this because logger
# fan-out is already enabled there.
SENTRY_CAPTURE_IN_DEVELOPMENT=""
# [server][required when SENTRY_ENABLED=true] Full Sentry DSN URL for server-side
# error reporting, for example "https://abc123@o000000.ingest.sentry.io/0000000".
SENTRY_DSN=""
# [server][optional] Logical deployment environment shown in Sentry, typically
# "development", "staging", or "production".
SENTRY_ENVIRONMENT=""
# [server][optional] Release identifier used for issue grouping and deploy
# tracking, for example a git SHA, image tag, or semver version.
SENTRY_RELEASE=""
# [client][optional] Set only if you also want browser-side crash reporting
# from the app and global React error boundaries. Use a full DSN URL or leave
# blank to keep Sentry server-only.
NEXT_PUBLIC_SENTRY_DSN=""


# ============================================================================
# Email / support
# ============================================================================
# [server][optional] Email transport backend. Options: "nodemailer", "resend"
EMAIL_PROVIDER="nodemailer"
# [server][required when EMAIL_PROVIDER=nodemailer for real delivery; dev can use MailHog]
SMTP_HOST="::1"
SMTP_PORT="1025"
SMTP_USER="admin@saasybase.com"
SMTP_PASS="password"
# [server][required when EMAIL_PROVIDER=resend]
RESEND_API_KEY=""
# SMTP settings are ignored when EMAIL_PROVIDER="resend".
# [server][required] Default sender/support identities.
EMAIL_FROM="support@saasybase.com"
SUPPORT_EMAIL="support@saasybase.com"
# [server][optional] Admin billing notification toggle.
SEND_ADMIN_BILLING_EMAILS="true"
# [server][optional] Additional outbound email target used by some workflows.
PARTNERS_EMAIL="partners@saasybase.com"
# [server][optional] IPinfo Lite token for country-level session geolocation. When unset, the activity page falls back to country.is API.
IPINFO_LITE_TOKEN=""


# ============================================================================
# Storage / branding assets
# ============================================================================
# [server][optional] File storage backend configuration.
# Options: "fs" (local filesystem, default) or "s3" (AWS S3 / S3-compatible object storage)
FILE_STORAGE=""
# [server][optional] S3-compatible bucket/endpoint and AWS credentials for uploaded assets.
FILE_S3_BUCKET=""
# [server][optional] Custom S3-compatible API endpoint for providers like Cloudflare R2, MinIO, or DigitalOcean Spaces. Leave blank for AWS S3.
FILE_S3_ENDPOINT=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# [client][optional] CDN hostname used when serving uploaded assets.
FILE_CDN_DOMAIN=""
# Legacy aliases still supported by the runtime: LOGO_STORAGE, LOGO_S3_BUCKET, LOGO_S3_ENDPOINT, LOGO_CDN_DOMAIN.


# ============================================================================
# Analytics
# ============================================================================
# [server][optional] External traffic analytics provider for /admin/traffic.
# Options: "google-analytics" or "posthog". External provider tracking
# intentionally skips /admin routes in the browser.
TRAFFIC_ANALYTICS_PROVIDER="posthog"
# [client][optional] GA4 browser tracking.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# [server][optional] GA Data API / reporting.
GA_PROPERTY_ID=""
GA_SERVICE_ACCOUNT_CREDENTIALS_B64=""
# [server][optional] Reporting cache TTL in seconds and lifetime chart start date override.
GA_DATA_API_CACHE_SECONDS="300"
GA_LIFETIME_START_DATE=""

# [server][optional when TRAFFIC_ANALYTICS_PROVIDER=posthog] PostHog Query API
# project id and personal API key with query:read scope.
POSTHOG_PROJECT_ID=""
POSTHOG_PERSONAL_API_KEY=""
# [client][optional when TRAFFIC_ANALYTICS_PROVIDER=posthog] Browser-side
# Project token (called "Project token" in the PostHog dashboard) and API host
# used for PostHog pageview capture.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# [server][optional when TRAFFIC_ANALYTICS_PROVIDER=posthog] PostHog app host
# used for Query API requests. Use your region or self-hosted app URL.
POSTHOG_APP_HOST="https://us.posthog.com"



# ============================================================================
# Security / internal ops
# ============================================================================
# [server][required in production] Used to encrypt sensitive data at rest, including reusable payment authorizations.
ENCRYPTION_SECRET=""
# [server][optional] Enable read-only product demo mode (blocks mutating /api requests except auth/webhooks)
DEMO_READ_ONLY_MODE="false"
# [server][required in production for detailed health diagnostics]
HEALTHCHECK_TOKEN="$"
# [server][recommended in production] Used by internal/server-to-server endpoints.
INTERNAL_API_TOKEN=""
# [server][required in production] Used by /api/cron/process-expiry.
CRON_PROCESS_EXPIRY_TOKEN=""
# [server][optional] Vercel Cron secret. When set on Vercel, cron invocations include Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=""

# ============================================================================
# Local development / testing helpers
# ============================================================================
# Local development should stay minimal. Add ad hoc debug values only when a
# current script or local workflow actually needs them.

# Sends warnings and errors to Sentry during local development when SENTRY_ENABLED is not "true". 
#Set to "true" to enable this behavior for testing Sentry integration from the admin settings page. 
# [server][optional] Comma-separated extra development origins for Next.js dev assets.
# Use this only when you access the dev server through a custom local domain or
# tunnel instead of plain localhost. Restart npm run dev after changing it.
ALLOWED_DEV_ORIGINS=""

# [server+client][optional] Public-site mode for marketing/docs/blog deployments
# that should keep admin sign-in available while hiding end-user account entry
# points and registration UI. This does not change dashboard route access.
ADMIN_ONLY_PUBLIC_SITE="false"
