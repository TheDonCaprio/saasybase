  "private": true,
  "scripts": {
    "predev": "node ./scripts/validate-env.js",
    "prebuild": "node ./scripts/validate-env.js",
    "dev": "next dev",
    "dev:full": "npx concurrently \"npm run dev -- -p 3000\" \"stripe listen --forward-to localhost:3000/api/stripe/webhook\"",
