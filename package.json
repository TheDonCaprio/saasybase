    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.3",
    "stripe": "^16.0.0",
    "svix": "^1.81.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
