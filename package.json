{
  "name": "saasybase-pro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "predev": "node ./scripts/validate-env.js && npm run generate:docs-search",
    "prebuild": "node ./scripts/validate-env.js && npm run generate:docs-search",
    "dev": "node ./scripts/run-with-secrets.js next dev --webpack",
    "dev:turbo": "node ./scripts/run-with-secrets.js next dev --turbopack",
    "dev:full": "npx concurrently \"npm run dev -- -p 3000\" \"stripe listen --forward-to localhost:3000/api/stripe/webhook\"",
    "build": "node ./scripts/run-with-secrets.js prisma generate && node ./scripts/run-with-secrets.js next build --webpack",
    "generate:docs-search": "node scripts/generate-docs-search-index.mjs",
    "compile-lib": "npx tsc -p tsconfig.lib.json",
    "start": "node ./scripts/run-with-secrets.js next start",
    "lint": "eslint .",
    "public:history:dry-run": "bash scripts/public-history/rewrite-history.sh",
    "public:history:validate": "node scripts/public-history/validate-public-history.mjs",
    "prisma:migrate": "node ./scripts/run-with-secrets.js prisma migrate dev --config prisma.config.ts",
    "prisma:deploy": "node ./scripts/run-with-secrets.js prisma migrate deploy --config prisma.config.ts",
    "prisma:studio": "node ./scripts/run-with-secrets.js prisma studio --config prisma.config.ts",
    "secrets:doctor": "node ./scripts/secrets-doctor.js",
    "secrets:smoke": "node ./scripts/secrets-smoke-test.js",
    "typecheck": "tsc --noEmit",
    "public:export": "node scripts/public-export.mjs",
    "public:publish": "bash scripts/publish-public-export.sh",
    "test": "vitest",
    "backfill:team-subscription-org-links": "tsx scripts/backfill-team-subscription-org-links.ts",
    "backfill:better-auth-coexistence": "tsx scripts/backfill-better-auth-coexistence.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@better-auth/prisma-adapter": "^1.6.5",
    "@clerk/nextjs": "^7.2.5",
    "@clerk/themes": "^2.4.57",
    "@clerk/ui": "^1.6.5",
    "@fortawesome/fontawesome-svg-core": "^6.5.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^6.5.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@google-analytics/data": "^5.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sentry/nextjs": "^10.49.0",
    "@solana/web3.js": "^1.98.4",
    "@stripe/react-stripe-js": "^5.4.0",
    "@stripe/stripe-js": "^8.5.2",
    "@tiptap/extension-color": "^3.7.2",
    "@tiptap/extension-highlight": "^3.7.2",
    "@tiptap/extension-history": "^3.10.0",
    "@tiptap/extension-horizontal-rule": "^3.10.0",
    "@tiptap/extension-image": "^3.7.2",
    "@tiptap/extension-link": "^3.7.2",
    "@tiptap/extension-placeholder": "^3.9.0",
    "@tiptap/extension-text-align": "^3.7.2",
    "@tiptap/extension-text-style": "^3.7.2",
    "@tiptap/extension-underline": "^3.7.2",
    "@tiptap/extension-youtube": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.5",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "file-type": "^22.0.0",
    "google-auth-library": "^10.4.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.3",
    "resend": "^6.10.0",
    "stripe": "^16.0.0",
    "svix": "^1.81.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "dompurify": "^3.4.0",
    "jsdom": "^29.0.1"
  },
  "overrides": {
    "protobufjs": "7.5.5",
    "@hono/node-server": "1.19.14",
    "hono": "4.12.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^20.0.0",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.38",
    "prisma": "^7.7.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.4"
  }
}
