{
  "name": "saasybase-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/validate-env.js",
    "prebuild": "node ./scripts/validate-env.js",
    "dev": "next dev --webpack",
    "dev:full": "npx concurrently \"npm run dev -- -p 3000\" \"stripe listen --forward-to localhost:3000/api/stripe/webhook\"",
    "build": "prisma generate && next build --webpack",
    "compile-lib": "npx tsc -p tsconfig.lib.json",
    "start": "next start",
    "lint": "eslint .",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "check:admin-api-parity": "tsx scripts/check-admin-api-parity.ts",
    "test": "vitest",
    "backfill:pending-subscription-payments": "tsx scripts/backfill-pending-subscription-payments.ts"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
