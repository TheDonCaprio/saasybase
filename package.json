    "@google-analytics/data": "^5.2.0",
    "@prisma/client": "^5.19.0",
    "@react-pdf/renderer": "3.4.4",
    "@stripe/react-stripe-js": "^5.4.0",
    "@stripe/stripe-js": "^8.5.2",
    "@tanstack/react-query": "^5.51.0",
    "@tiptap/extension-color": "^3.7.2",
    "@tiptap/extension-highlight": "^3.7.2",
    "@tiptap/extension-history": "^3.10.0",
    "@tiptap/extension-horizontal-rule": "^3.10.0",
    "@tiptap/extension-image": "^3.7.2",
    "@tiptap/extension-link": "^3.7.2",
    "@tiptap/extension-placeholder": "^3.9.0",
    "@tiptap/extension-text-align": "^3.7.2",
    "@tiptap/extension-text-style": "^3.7.2",
    "@tiptap/extension-underline": "^3.7.2",
    "@tiptap/extension-youtube": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "@types/react-resizable": "^3.0.8",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
